{
  "name": "@andrewpopov/url-guard",
  "version": "0.1.4",
  "description": "SSRF guard for server-side fetches of user-supplied URLs: blocks non-http(s)/credentialed/disallowed-port URLs, localhost + internal-suffix hosts, and IP literals or DNS resolutions in private/reserved ranges (IPv4 + rigorous IPv6).",
  "author": "Andrew Popov",
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/andrewpopov/url-guard.git" },
  "bugs": { "url": "https://github.com/andrewpopov/url-guard/issues" },
  "homepage": "https://github.com/andrewpopov/url-guard#readme",
  "keywords": [
    "ssrf",
    "security",
    "url-validation",
    "server-side-requests",
    "typescript"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:pack": "node scripts/verify-pack.mjs",
    "verify:dist-fresh": "node scripts/verify-dist-fresh.mjs",
    "verify": "npm run typecheck && npm test && npm run build && npm run verify:pack",
    "release:note": "release-kit note",
    "release:notes": "release-kit notes",
    "release:bump": "release-kit bump",
    "release:cut": "release-kit cut",
    "release:check": "release-kit check",
    "release:hygiene": "release-kit hygiene"
  },
  "devDependencies": {
    "@andrewpopov/release-kit": "github:andrewpopov/release-kit#v0.2.0",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
  }
}
